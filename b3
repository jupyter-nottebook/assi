import pandas as pd
import matplotlib.pyplot as plt
import seaborn as sns

# Load dataset
df = pd.read_csv("forestfires.csv")

print(df.head())

#Count of Fires per Month(Bar Chart)

plt.figure(figsize=(10,6))
sns.countplot(x='month', data=df, order=df['month'].value_counts().index)
plt.title("Number of Forest Fires per Month")
plt.xlabel("Month")
plt.ylabel("Count of Fires")
plt.show()

#Temperature Distribution(Histogram)

plt.figure(figsize=(8,5))
sns.histplot(df['temp'], bins=20, kde=True)
plt.title("Temperature Distribution")
plt.xlabel("Temperature")
plt.ylabel("Frequency")
plt.show()

#Burned Area vs Temperature(Scatter Plot)

plt.figure(figsize=(8,6))
sns.scatterplot(x='temp', y='area', data=df)
plt.title("Burned Area vs Temperature")
plt.xlabel("Temperature")
plt.ylabel("Burned Area")
plt.show()

#Wind Speed vs Burned Area(Scatter Plot)

plt.figure(figsize=(8,6))
sns.scatterplot(x='wind', y='area', data=df)
plt.title("Wind Speed vs Burned Area")
plt.xlabel("Wind Speed")
plt.ylabel("Burned Area")
plt.show()

#Average Temperature per Month (Bar Plot)

plt.figure(figsize=(10,6))
sns.barplot(x='month', y='temp', data=df, estimator='mean')
plt.title("Average Temperature per Month")
plt.xlabel("Month")
plt.ylabel("Average Temperature")
plt.show()

#Box Plot of Burened Area
plt.figure(figsize=(8,6))
sns.boxplot(x='month', y='area', data=df)
plt.title("Burned Area Distribution per Month")
plt.xlabel("Month")
plt.ylabel("Burned Area")
plt.show()

# Count fires per month
month_counts = df['month'].value_counts()

# Plot Pie Chart
plt.figure(figsize=(10,6))
plt.pie(month_counts, 
        labels=month_counts.index, 
        autopct='%1.1f%%', #Autopct is used to display percentage values on the pie chart slices.
        startangle=90)

plt.title("Distribution of Forest Fires by Month")
plt.axis('equal')  # Makes pie circular
plt.show()











