import	pandas	as	pd
import	numpy	as	np
from	sklearn.model_selection	import	train_test_split
from	sklearn.preprocessing	import	PowerTransformer
from	sklearn.linear_model	import	LogisticRegression
from	sklearn.tree	import	DecisionTreeClassifier
from	sklearn.metrics	import	accuracy_score,	precision_score,	recall_score

#	Load	dataset
df	=	pd.read_csv(r"C:\TE	Year\2nd	sem\practicals\dsbdal\heart.csv")

#	DATA	CLEANING
#	Remove	outliers	(1%	-	99%)
num_cols	=	['age',	'trestbps',	'chol',	'thalach',	'oldpeak']
def	remove_outliers(data,	columns):
for	col	in	columns:
low	=	data[col].quantile(0.01)
high	=	data[col].quantile(0.99)
data	=	data[(data[col]	>=	low)	&	(data[col]	<=	high)]
return	data
df_clean	=	remove_outliers(df.copy(),	num_cols).reset_index(drop=True)

#	Remove	missing	values	
df_clean.dropna(inplace=True)

#	DATA	INTEGRATION
dataset	=	df_clean.copy()

#	DATA	TRANSFORMATION
pt	=	PowerTransformer(method='yeo-johnson')
X	=	dataset.drop('target',	axis=1)
y	=	dataset['target']
X_transformed	=	pd.DataFrame(pt.fit_transform(X),	columns=X.columns)

#	ERROR	CORRECTING
#	Proper	duplicate	removal
dataset	=	pd.concat([X_transformed,	y],	axis=1).drop_duplicates()
X_transformed	=	dataset.drop('target',	axis=1)
y	=	dataset['target']

#	MODEL	BUILDING
X_train,	X_test,	y_train,	y_test	=	train_test_split(X_transformed,	y,	test_size=0.2,	random_state=42)

#	Logistic	Regression
lr_model	=	LogisticRegression()
lr_model.fit(X_train,	y_train)

#	Decision	Tree
dt_model	=	DecisionTreeClassifier(random_state=42)
dt_model.fit(X_train,	y_train)

#	ORIGINAL	PREDICTIONS	(0.6	threshold)
lr_preds	=	lr_model.predict(X_test)
dt_preds	=	dt_model.predict(X_test)

#	FUNCTION	FOR	METRICS
def	print_metrics(name,	y_true,	y_pred):
print(f"\n{name}	Model	Performance:")
print(f"		Accuracy	:	{accuracy_score(y_true,	y_pred)*100:.2f}%")
print(f"		Precision:	{precision_score(y_true,	y_pred):.4f}")
print(f"		Recall			:	{recall_score(y_true,	y_pred):.4f}")

#result
print("	RESULTS	")
print_metrics("Logistic	Regression",	y_test,	lr_preds)
print_metrics("Decision	Tree",	y_test,	dt_preds)

#	THRESHOLD	TUNING	(for	fixing	over	predicting	positives)
y_probs	=	lr_model.predict_proba(X_test)[:,	1]

#	Change	threshold	from	0.6	→	0.7
threshold	=	0.7
lr_preds_tuned	=	(y_probs	>	threshold).astype(int)
print("	AFTER	THRESHOLD	TUNING	(0.7)	")
print_metrics("Logistic	Regression	(Tuned)",	y_test,	lr_preds_tuned)

#	Decision	Tree	probabilities
dt_probs	=	dt_model.predict_proba(X_test)[:,	1]
#	Apply	same	threshold	(0.7)
dt_preds_tuned	=	(dt_probs	>	0.7).astype(int)
print("\nDecision	Tree	(Tuned)	Model	Performance:")
print(f"		Accuracy	:	{accuracy_score(y_test,	dt_preds_tuned)*100:.2f}%")
print(f"		Precision:	{precision_score(y_test,	dt_preds_tuned):.4f}")
print(f"		Recall			:	{recall_score(y_test,	dt_preds_tuned):.4f}")

#note:
#Decision	Trees:
#Already	make	hard	decisions	(0	or	1)
#Their	probability	outputs	are	not	smooth	like	Logistic	Regression
#So	when	you	apply:
#threshold	=	0.7
#It	often:
#Does	NOT	change	predictions	much
#Or	sometimes	no	change	at	all
#Threshold	tuning	is	effective	mainly	for	probabilistic	models	like	Logistic	Regression,	not	for	Decision	Trees.







